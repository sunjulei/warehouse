<template>
  <view class="login-page">
    <!-- Logo -->
    <view class="logo-area">
      <view class="logo-icon">
        <text class="icon-text">📦</text>
      </view>
      <text class="app-name">仓储脉搏</text>
      <text class="app-desc">智能仓库管理系统</text>
    </view>

    <!-- 表单 -->
    <view class="form-card">
      <text class="form-title">账号登录</text>

      <!-- 用户名 -->
      <text class="label">用户名</text>
      <view class="input-wrap">
        <input
          class="input"
          placeholder="请输入用户名"
          :value="loginname"
          @input="onLoginnameInput"
        />
      </view>

      <!-- 密码 -->
      <text class="label">密码</text>
      <view class="input-wrap">
        <input
          class="input"
          placeholder="请输入密码"
          :password="!showPwd"
          :value="pwd"
          @input="onPwdInput"
        />
        <text class="eye" @click="showPwd = !showPwd">{{ showPwd ? '隐藏' : '显示' }}</text>
      </view>

      <!-- 验证码 -->
      <text class="label">验证码</text>
      <view class="captcha-row">
        <view class="input-wrap captcha-input">
          <input
            class="input"
            placeholder="请输入验证码"
            :value="code"
            @input="onCodeInput"
          />
        </view>
        <view class="captcha-img-wrap" @click="refreshCaptcha">
          <image
            v-if="captchaImage"
            class="captcha-img"
            :src="captchaImage"
            mode="scaleToFill"
          />
          <text v-else class="captcha-loading">...</text>
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="login-btn" :class="{ disabled: loading }" @click="handleLogin">
        <text class="btn-text">{{ loading ? '登录中...' : '登 录' }}</text>
      </view>
    </view>

    <text class="footer">Warehouse Pulse v1.0</text>
  </view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { login, getCaptchaBase64 } from '../../api/login'
import { fetchCurrentUser } from '../../stores/auth'

const loginname = ref('admin')
const pwd = ref('123456')
const code = ref('')
const captchaId = ref('')
const captchaAnswer = ref('')
const captchaImage = ref('')
const loading = ref(false)
const showPwd = ref(false)

function onLoginnameInput(e: UniInputEvent) {
  loginname.value = e.detail.value
}

function onPwdInput(e: UniInputEvent) {
  pwd.value = e.detail.value
}

function onCodeInput(e: UniInputEvent) {
  code.value = e.detail.value
}

function refreshCaptcha() {
  captchaImage.value = ''
  code.value = ''
  captchaAnswer.value = ''
  getCaptchaBase64().then((res: any) => {
    const data = res as UTSJSONObject
    const code200 = data['code'] as number
    if (code200 == 200) {
      captchaId.value = (data['captchaId'] as string) ?? ''
      captchaAnswer.value = (data['captchaCode'] as string) ?? ''
      const img = (data['image'] as string) ?? ''
      if (img.length > 0) {
        captchaImage.value = img
      } else {
        uni.showToast({ title: '验证码图片数据为空', icon: 'none' })
      }
    } else {
      uni.showToast({ title: (data['msg'] as string) ?? '获取验证码失败', icon: 'none' })
    }
  }).catch((err: any) => {
    const msg = typeof err === 'string' ? err : (err.message ?? '获取验证码失败')
    uni.showToast({ title: msg, icon: 'none' })
  })
}

onMounted(() => {
  refreshCaptcha()
})

function handleLogin() {
  if (loading.value) return
  const name = loginname.value.trim()
  const password = pwd.value.trim()
  const captchaCode = code.value.trim()

  if (name.length == 0) {
    uni.showToast({ title: '请输入用户名', icon: 'none' })
    return
  }
  if (password.length == 0) {
    uni.showToast({ title: '请输入密码', icon: 'none' })
    return
  }

  loading.value = true
  login(name, password, captchaCode, captchaId.value, captchaAnswer.value).then(() => {
    return fetchCurrentUser()
  }).then(() => {
    uni.showToast({ title: '登录成功', icon: 'success' })
    setTimeout(() => {
      uni.switchTab({ url: '/pages/workbench/index' })
    }, 500)
  }).catch((err: any) => {
    const msg = typeof err === 'string' ? err : '登录失败'
    uni.showToast({ title: msg, icon: 'none' })
    refreshCaptcha()
  }).finally(() => {
    loading.value = false
  })
}
</script>

<style lang="scss">
