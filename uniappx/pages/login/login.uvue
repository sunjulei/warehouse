  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #2C7BE5 0%, #1A56DB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(44, 123, 229, 0.3);
}

