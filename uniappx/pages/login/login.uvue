<template>
  <view class="login-page">
    <!-- 顶部装饰 -->
    <view class="top-decor">
      <view class="decor-circle c1"></view>
      <view class="decor-circle c2"></view>
    </view>

    <!-- Logo 区域 -->
    <view class="logo-area">
      <view class="logo-icon">
        <text class="icon-text">📦</text>
      </view>
      <text class="app-name">仓储脉搏</text>
      <text class="app-desc">智能仓库管理系统</text>
    </view>

    <!-- 登录表单 -->
    <view class="form-card">
      <view class="form-title">
        <text class="title-text">账号登录</text>
      </view>

      <!-- 用户名 -->
      <view class="input-group">
        <view class="input-icon">
          <text class="icon">👤</text>
        </view>
        <input
          class="input-field"
          placeholder="请输入用户名"
          :value="loginname"
          @input="onLoginnameInput"
        />
      </view>

      <!-- 密码 -->
      <view class="input-group">
        <view class="input-icon">
          <text class="icon">🔒</text>
        </view>
        <input
          class="input-field"
          placeholder="请输入密码"
          :password="!showPwd"
          :value="pwd"
          @input="onPwdInput"
        />
        <view class="eye-btn" @click="showPwd = !showPwd">
          <text class="icon">{{ showPwd ? '👁️' : '🙈' }}</text>
        </view>
      </view>

      <!-- 验证码 -->
      <view class="captcha-row">
        <view class="input-group captcha-input">
          <view class="input-icon">
            <text class="icon">🔐</text>
          </view>
          <input
            class="input-field"
            placeholder="验证码"
            :value="code"
            @input="onCodeInput"
          />
        </view>
        <view class="captcha-img-wrap" @click="refreshCaptcha">
          <image
            v-if="captchaImage"
            class="captcha-img"
            :src="captchaImage"
            mode="scaleToFill"
          />
          <text v-else class="captcha-loading">加载中...</text>
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="login-btn" :class="{ disabled: loading }" @click="handleLogin">
        <text class="btn-text">{{ loading ? '登录中...' : '登 录' }}</text>
      </view>
    </view>

    <!-- 底部 -->
    <view class="footer">
      <text class="footer-text">Warehouse Pulse v1.0</text>
    </view>
  </view>
</template>

<script setup lang="ts">
import { ref, onMounted } from 'vue'
import { login, getCaptchaBase64 } from '../../api/login.uts'

const loginname = ref('')
const pwd = ref('')
const code = ref('')
const captchaId = ref('')
const captchaImage = ref('')
const loading = ref(false)
const showPwd = ref(false)

function onLoginnameInput(e: UniInputEvent) {
  loginname.value = e.detail.value
}

function onPwdInput(e: UniInputEvent) {
  pwd.value = e.detail.value
}

function onCodeInput(e: UniInputEvent) {
  code.value = e.detail.value
}

// 加载验证码
function refreshCaptcha() {
  captchaImage.value = ''
  code.value = ''
  getCaptchaBase64().then((data: UTSJSONObject) => {
    captchaId.value = data['captchaId'] as string
    captchaImage.value = data['image'] as string
  }).catch((err: any) => {
    console.error('获取验证码失败', err)
    uni.showToast({ title: '获取验证码失败', icon: 'none' })
  })
}

onMounted(() => {
  refreshCaptcha()
})

function handleLogin() {
  if (loading.value) return
  const name = loginname.value.trim()
  const password = pwd.value.trim()
  const captchaCode = code.value.trim()

  if (name.length == 0) {
    uni.showToast({ title: '请输入用户名', icon: 'none' })
    return
  }
  if (password.length == 0) {
    uni.showToast({ title: '请输入密码', icon: 'none' })
    return
  }
  if (captchaCode.length == 0) {
    uni.showToast({ title: '请输入验证码', icon: 'none' })
    return
  }

  loading.value = true
  login(name, password, captchaCode, captchaId.value).then(() => {
    uni.showToast({ title: '登录成功', icon: 'success' })
    setTimeout(() => {
      uni.switchTab({ url: '/pages/index/index' })
    }, 500)
  }).catch((err: any) => {
    const msg = typeof err === 'string' ? err : '登录失败'
    uni.showToast({ title: msg, icon: 'none' })
    refreshCaptcha()
  }).finally(() => {
    loading.value = false
  })
}
</script>

