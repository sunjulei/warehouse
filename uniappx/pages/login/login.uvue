  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2C7BE5, #1A56DB);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 56rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #0F172A;
  margin-top: 24rpx;
}

.app-desc {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.form-card {
  width: 650rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
  margin-bottom: 36rpx;
}

.label {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 12rpx;
}

.input-wrap {
  flex-direction: row;
  align-items: center;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  height: 88rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  margin-bottom: 28rpx;
}

.input {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: #0F172A;
}

.eye {
  font-size: 32rpx;
  padding: 10rpx;
}

.captcha-row {
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-img-wrap {
  width: 220rpx;
  height: 88rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.captcha-img {
  width: 220rpx;
  height: 88rpx;
}

.captcha-loading {
  font-size: 26rpx;
  color: #94A3B8;
}

.login-btn {
  height: 92rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #2C7BE5, #1A56DB);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
}

.login-btn.disabled {
  opacity: 0.6;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.footer {
  margin-top: 60rpx;
  font-size: 24rpx;
  color: #CBD5E1;
}
</style>
