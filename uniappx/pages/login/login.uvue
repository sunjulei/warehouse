  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 10rpx;
}

.form-card {
  margin: 60rpx 48rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  position: relative;
  z-index: 1;
}

.form-title {
  margin-bottom: 40rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
}

.input-group {
  display: flex;
  align-items: center;
