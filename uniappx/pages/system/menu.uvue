}

.tree-child-text {
  font-size: 24rpx;
  color: #666666;
}

/* 右侧列表 */
.list-section {
  flex: 1;
  flex-direction: column;
}

.section-header {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #FFFFFF;
  border-bottom-width: 1rpx;
  border-bottom-style: solid;
  border-bottom-color: #F0F0F0;
}

.section-title {
