<template>
  <!-- #ifdef APP -->
  <scroll-view style="flex:1">
  <!-- #endif -->
  <view class="container">
    <!-- 菜单树（左侧） -->
    <view class="tree-section">
      <view class="tree-header">
        <text class="tree-title">菜单结构</text>
        <view class="tree-refresh-btn" @click="loadTreeData">
          <text class="tree-refresh-text">刷新</text>
        </view>
      </view>
      <scroll-view style="flex:1">
        <view class="tree-container">
          <view class="tree-item-root" @click="selectRootMenu">
            <text class="tree-item-text" :class="{ 'tree-item-active': selectedMenuId == null }">全部菜单</text>
          </view>
          <view v-for="(item, index) in treeData" :key="index">
            <view class="tree-item" @click="selectMenu(item)">
              <text class="tree-item-text" :class="{ 'tree-item-active': selectedMenuId == (item['id'] as number) }">
                {{ item['title'] ?? '' }}
              </text>
            </view>
            <view v-if="item['children'] != null" class="tree-children">
              <view v-for="(child, ci) in (item['children'] as UTSJSONObject[])" :key="ci" class="tree-child-item" @click="selectMenu(child)">
                <text class="tree-child-text" :class="{ 'tree-item-active': selectedMenuId == (child['id'] as number) }">
                  └ {{ child['title'] ?? '' }}
                </text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 菜单列表（右侧） -->
    <view class="list-section">
      <view class="section-header">
        <text class="section-title">{{ selectedMenuName ?? '全部菜单' }}</text>
        <view class="add-btn" @click="openForm()">
          <text class="add-btn-text">+ 添加</text>
        </view>
      </view>

      <scroll-view
        style="flex:1"
        @scrolltolower="onLoadMore"
        refresher-enabled
        :refresher-triggered="refreshing"
        @refresherrefresh="onRefresh"
      >
        <view v-if="menuList.length > 0" class="list-container">
          <view v-for="(item, index) in menuList" :key="index" class="menu-card">
            <view class="menu-info">
              <view class="menu-row">
                <text class="menu-label">菜单名：</text>
                <text class="menu-value">{{ item['title'] ?? '' }}</text>
              </view>
              <view class="menu-row">
                <text class="menu-label">图标：</text>
                <text class="menu-value">{{ item['icon'] ?? '' }}</text>
              </view>
              <view class="menu-row">
                <text class="menu-label">路径：</text>
                <text class="menu-value">{{ item['href'] ?? '' }}</text>
              </view>
              <view class="menu-row">
                <text class="menu-label">排序：</text>
                <text class="menu-value">{{ item['ordernum'] ?? 0 }}</text>
              </view>
              <view class="menu-row">
                <text class="menu-label">可用：</text>
                <text class="menu-value" :class="(item['available'] as number) == 1 ? 'status-on' : 'status-off'">
                  {{ (item['available'] as number) == 1 ? '是' : '否' }}
                </text>
              </view>
            </view>
            <view class="menu-actions">
              <view class="action-btn action-edit" @click="openForm(item)">
                <text class="action-text edit-text">编辑</text>
              </view>
              <view class="action-btn action-delete" @click="handleDelete(item)">
                <text class="action-text delete-text">删除</text>
              </view>
            </view>
          </view>
          <view class="loading-row">
            <text class="loading-text">{{ loadingText }}</text>
          </view>
        </view>

        <view v-if="!loading && menuList.length === 0" class="empty-state">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无菜单数据</text>
        </view>
      </scroll-view>
    </view>

    <!-- 添加/编辑弹窗 -->
    <view v-if="formVisible" class="form-overlay" @click="closeForm">
      <view class="form-popup" @click.stop>
        <view class="form-header">
          <text class="form-title">{{ isEdit ? '编辑菜单' : '添加菜单' }}</text>
          <view class="form-close" @click="closeForm">
            <text class="close-icon">✕</text>
          </view>
        </view>

        <scroll-view style="flex:1" class="form-body">
          <view class="form-fields">
            <view class="form-item">
              <text class="form-label">上级菜单</text>
              <picker :range="parentMenuLabels" @change="onParentMenuChange">
                <view class="form-picker">
                  <text class="picker-text">{{ selectedParentLabel || '请选择上级菜单' }}</text>
                  <text class="picker-arrow">▼</text>
                </view>
              </picker>
            </view>
            <view class="form-item">
              <text class="form-label">菜单名 <text class="required-mark">*</text></text>
              <input class="form-input" placeholder="请输入菜单名" :value="formData['title']" @input="onFormInput($event, 'title')" />
            </view>
            <view class="form-item">
              <text class="form-label">图标</text>
              <input class="form-input" placeholder="请输入图标名称" :value="formData['icon']" @input="onFormInput($event, 'icon')" />
            </view>
            <view class="form-item">
              <text class="form-label">路径</text>
              <input class="form-input" placeholder="请输入路径" :value="formData['href']" @input="onFormInput($event, 'href')" />
            </view>
            <view class="form-item">
              <text class="form-label">排序号</text>
              <input class="form-input" type="number" placeholder="请输入排序号" :value="formData['ordernum']" @input="onFormInput($event, 'ordernum')" />
            </view>
            <view class="form-item">
              <text class="form-label">是否展开</text>
              <switch :checked="(formData['open'] as number) == 1" @change="onOpenChange" />
            </view>
            <view class="form-item">
              <text class="form-label">是否可用</text>
              <switch :checked="(formData['available'] as number) == 1" @change="onAvailableChange" />
            </view>
          </view>
        </scroll-view>

        <view class="form-footer">
          <view class="btn-cancel" @click="closeForm">
            <text class="btn-text">取消</text>
          </view>
          <view class="btn-submit" @click="handleSubmit">
            <text class="btn-text btn-text-white">{{ submitting ? '提交中...' : '保存' }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <!-- #ifdef APP -->
  </scroll-view>
  <!-- #endif -->
</template>

<script setup lang="uts">
import { ref, computed } from 'vue'
import { loadMenuManagerLeftTreeJson, loadAllMenu, addMenu, updateMenu, deleteMenu, loadMenuMaxOrderNum } from '../../api/menu'
import { checkPagePermission } from '../../utils/auth-guard'

// 菜单树
const treeData = ref<UTSJSONObject[]>([])
const selectedMenuId = ref<number | null>(null)
const selectedMenuName = ref<string | null>(null)

// 菜单列表
const menuList = ref<UTSJSONObject[]>([])
const loading = ref(false)
const noMore = ref(false)
const refreshing = ref(false)
const page = ref(1)
const limit = 20

// 表单
const formVisible = ref(false)
const isEdit = ref(false)
const editId = ref<number | null>(null)
const submitting = ref(false)
const formData = ref<UTSJSONObject>({} as UTSJSONObject)

// 上级菜单选择
const parentMenuLabels = ref<string[]>([])
const parentMenuIds = ref<number[]>([])
const selectedParentLabel = ref('')

const loadingText = computed((): string => {
  if (loading.value) return '加载中...'
  if (noMore.value && menuList.value.length > 0) return '没有更多了'
  return ''
})

/**
 * 加载菜单树
 */
function loadTreeData(): void {
  loadMenuManagerLeftTreeJson().then((res: any) => {
    const result = res as UTSJSONObject
    const data = result['data'] as UTSJSONObject[] | null
    if (data != null) {
      treeData.value = data!
    }
  }).catch((err: Error) => {
    console.error('加载菜单树失败:', err.message)
  })
}

/**
 * 选择根菜单
 */
function selectRootMenu(): void {
  selectedMenuId.value = null
  selectedMenuName.value = null
  loadMenuList(true)
}

/**
 * 选择菜单
 */
function selectMenu(item: UTSJSONObject): void {
  selectedMenuId.value = item['id'] as number
  selectedMenuName.value = item['title'] as string
  loadMenuList(true)
}

/**
 * 加载菜单列表
 */
function loadMenuList(isRefresh: boolean): void {
  if (loading.value) return
  if (isRefresh) {
    page.value = 1
    noMore.value = false
    menuList.value = []
  }
  if (noMore.value) return

  loading.value = true
  const params = {} as UTSJSONObject
  params['page'] = isRefresh ? 1 : page.value
  params['limit'] = limit
  if (selectedMenuId.value != null) {
    params['id'] = selectedMenuId.value
  }

  loadAllMenu(params).then((res: any) => {
    const result = res as UTSJSONObject
    const code = result['code'] as number
    if (code == 0) {
      const list = result['data'] as UTSJSONObject[] | null
      if (list != null && list!.length > 0) {
        const newItems = list!
        menuList.value = menuList.value.concat(newItems)
        page.value = page.value + 1
        if (newItems.length < limit) {
          noMore.value = true
        }
      } else {
        noMore.value = true
      }
    }
    loading.value = false
    refreshing.value = false
  }).catch((err: Error) => {
    loading.value = false
    refreshing.value = false
    console.error('加载菜单列表失败:', err.message)
  })
}

function onRefresh(): void {
  refreshing.value = true
  loadMenuList(true)
}

function onLoadMore(): void {
  if (!noMore.value && !loading.value) {
    loadMenuList(false)
  }
}

/**
 * 构建上级菜单选择器数据
 */
function buildParentMenuOptions(): void {
  const labels: string[] = ['顶级菜单']
  const ids: number[] = [0]

  for (let i = 0; i < treeData.value.length; i++) {
    const item = treeData.value[i]
    labels.push(item['title'] as string)
    ids.push(item['id'] as number)

    const children = item['children'] as UTSJSONObject[] | null
    if (children != null) {
      for (let j = 0; j < children!.length; j++) {
        const child = children![j]
        labels.push('  └ ' + (child['title'] as string))
        ids.push(child['id'] as number)
      }
    }
  }

  parentMenuLabels.value = labels
  parentMenuIds.value = ids
}

function onParentMenuChange(e: any): void {
  const index = e.detail.value as number
  if (index < parentMenuIds.value.length) {
    const id = parentMenuIds.value[index]
    formData.value['pid'] = id == 0 ? null : id
    selectedParentLabel.value = parentMenuLabels.value[index]
  }
}

/**
 * 表单输入处理
 */
function onFormInput(e: UniInputEvent, key: string): void {
  formData.value[key] = e.detail.value
}

function onOpenChange(e: any): void {
  formData.value['open'] = e.detail.value ? 1 : 0
}

function onAvailableChange(e: any): void {
  formData.value['available'] = e.detail.value ? 1 : 0
}

/**
 * 打开表单
 */
async function openForm(data: UTSJSONObject | null = null): Promise<void> {
  buildParentMenuOptions()

  if (data != null) {
    isEdit.value = true
    editId.value = data['id'] as number
    const pid = data['pid'] as number | null
    formData.value = {
      title: (data['title'] as string) ?? '',
      icon: (data['icon'] as string) ?? '',
      href: (data['href'] as string) ?? '',
      ordernum: (data['ordernum'] as number) ?? 0,
      open: (data['open'] as number) ?? 0,
      available: (data['available'] as number) ?? 1,
      pid: pid
    } as UTSJSONObject

    // 设置上级菜单显示
    if (pid != null) {
      const idx = parentMenuIds.value.indexOf(pid!)
      selectedParentLabel.value = idx >= 0 ? parentMenuLabels.value[idx] : ''
    } else {
      selectedParentLabel.value = '顶级菜单'
    }
  } else {
    isEdit.value = false
    editId.value = null
    // 获取最大排序号
    loadMenuMaxOrderNum().then((res: any) => {
      const result = res as UTSJSONObject
      const maxNum = result['value'] as number ?? 0
      formData.value = {
        title: '',
        icon: '',
        href: '',
        ordernum: maxNum + 1,
        open: 0,
        available: 1,
        pid: selectedMenuId.value
      } as UTSJSONObject
    }).catch(() => {
      formData.value = {
        title: '',
        icon: '',
        href: '',
        ordernum: 1,
        open: 0,
        available: 1,
        pid: selectedMenuId.value
      } as UTSJSONObject
    })
    selectedParentLabel.value = selectedMenuId.value != null ? '' : '顶级菜单'
  }
  formVisible.value = true
}

function closeForm(): void {
  formVisible.value = false
}

/**
 * 提交表单
 */
function handleSubmit(): void {
  if (submitting.value) return

  const title = (formData.value['title'] as string) ?? ''
  if (title.length == 0) {
    uni.showToast({ title: '请输入菜单名', icon: 'none' })
    return
  }

  submitting.value = true
  const submitData = {} as UTSJSONObject
  submitData['title'] = formData.value['title']
  submitData['icon'] = formData.value['icon']
  submitData['href'] = formData.value['href']
  submitData['ordernum'] = formData.value['ordernum']
  submitData['open'] = formData.value['open']
  submitData['available'] = formData.value['available']
  submitData['pid'] = formData.value['pid']

  let api: Promise<any>
  if (isEdit.value && editId.value != null) {
    submitData['id'] = editId.value
    api = updateMenu(submitData)
  } else {
    api = addMenu(submitData)
  }

  api.then((res: any) => {
    submitting.value = false
    const result = res as UTSJSONObject
    const code = result['code'] as number ?? -1
    if (code == 200) {
      uni.showToast({ title: '操作成功', icon: 'success' })
      closeForm()
      loadMenuList(true)
      loadTreeData()
    } else {
      const msg = result['msg'] as string ?? '操作失败'
      uni.showToast({ title: msg, icon: 'none' })
    }
  }).catch((err: Error) => {
    submitting.value = false
    uni.showToast({ title: '操作失败', icon: 'none' })
  })
}

/**
 * 删除菜单
 */
function handleDelete(item: UTSJSONObject): void {
  const title = (item['title'] as string) ?? ''
  uni.showModal({
    title: '确认删除',
    content: '确认删除菜单「' + title + '」？',
    success: (res) => {
      if (res.confirm) {
        const id = item['id'] as number
        deleteMenu(id).then((r: any) => {
          const result = r as UTSJSONObject
          const code = result['code'] as number ?? -1
          if (code == 200) {
            uni.showToast({ title: '删除成功', icon: 'success' })
            loadMenuList(true)
            loadTreeData()
          } else {
            const msg = result['msg'] as string ?? '删除失败'
            uni.showToast({ title: msg, icon: 'none' })
          }
        }).catch((err: Error) => {
          uni.showToast({ title: '删除失败', icon: 'none' })
        })
      }
    }
  })
}

/**
 * 页面加载
 */
onShow(() => {
  if (!checkPagePermission('/system/menu')) return
  loadTreeData()
  loadMenuList(true)
})
</script>

<style>
.container {
  flex: 1;
  flex-direction: row;
  background-color: #F5F7FA;
}

