.period-section {
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
}

.period-list {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.period-item {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background-color: #F5F7FA;
}

.period-item-active {
  background-color: #409EFF;
}

.period-text {
  font-size: 24rpx;
  color: #606266;
}

.period-text-active {
  color: #FFFFFF;
  font-weight: bold;
}

/* 自定义日期 */
.custom-date-row {
  flex-direction: row;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.date-picker-wrap {
  flex: 1;
  flex-direction: column;
  gap: 4rpx;
}

.date-label {
  font-size: 22rpx;
  color: #909399;
}

.date-display {
  background-color: #F5F7FA;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  border-width: 1rpx;
  border-style: solid;
  border-color: #DCDFE6;
}

.date-value {
  font-size: 26rpx;
  color: #333333;
}

.date-separator {
  font-size: 26rpx;
  color: #909399;
  margin-top: 28rpx;
}

.query-btn {
  background-color: #409EFF;
  border-radius: 8rpx;
  padding: 12rpx 28rpx;
  margin-top: 28rpx;
}

.query-btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
}

/* 数据区域 */
.data-section {
  padding: 20rpx 24rpx;
}

.data-header {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.data-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #303133;
}

.data-count {
  font-size: 24rpx;
  color: #909399;
}

/* 汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, #409EFF, #66b1ff);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  align-items: center;
}

.summary-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

