  font-size: 40rpx;
  font-weight: bold;
  color: #303133;
}

.page-desc {
  font-size: 26rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 标签栏 */
.tab-bar {
  background-color: #FFFFFF;
  border-bottom-width: 1rpx;
  border-bottom-style: solid;
  border-bottom-color: #F0F0F0;
}

.tab-scroll {
  white-space: nowrap;
}

.tab-list {
  flex-direction: row;
  padding: 0 12rpx;
}

.tab-item {
  padding: 20rpx 24rpx;
  border-bottom-width: 4rpx;
  border-bottom-style: solid;
  border-bottom-color: transparent;
}

.tab-item-active {
  border-bottom-color: #409EFF;
}

.tab-text {
  font-size: 26rpx;
  color: #606266;
}

.tab-text-active {
  color: #409EFF;
  font-weight: bold;
}

