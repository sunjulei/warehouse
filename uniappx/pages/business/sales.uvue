  color: #333333;
}

.cart-item-price {
  font-size: 24rpx;
  color: #999999;
}

.cart-item-right {
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.cart-item-subtotal {
  font-size: 28rpx;
