  font-size: 24rpx;
  color: #F56C6C;
}

.add-btn {
  background-color: #409EFF;
  border-radius: 8rpx;
  padding: 12rpx 28rpx;
}

.add-btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
}

/* 购物车区域 */
.cart-section {
  padding: 20rpx 24rpx;
}

.cart-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.cart-header {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

