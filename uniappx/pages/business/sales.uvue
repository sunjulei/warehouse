  font-size: 24rpx;
  color: #F56C6C;
}

.cart-item {
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
  border-bottom-width: 1rpx;
  border-bottom-style: solid;
  border-bottom-color: #F0F0F0;
}

.cart-item-info {
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.cart-item-name {
