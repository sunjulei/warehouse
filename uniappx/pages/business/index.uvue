<script setup lang="uts">
import { ref } from 'vue'

interface TabItem {
  title : string
}

const tabs = ref<TabItem[]>([
  { title: '商品' },
  { title: '进货' },
  { title: '销售' },
  { title: '盘点' }
])

const currentTab = ref(0)

function onTabClick(index : number) : void {
  currentTab.value = index
}

function navigateTo(url : string) : void {
  uni.navigateTo({ url: url })
}
</script>

