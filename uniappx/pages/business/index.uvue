    <view class="tab-bar">
      <view
        v-for="(tab, index) in tabs"
        :key="index"
        class="tab-item"
        @click="onTabClick(index)"
      >
        <text class="tab-text" :class="currentTab === index ? 'tab-text-active' : ''">{{ tab.title }}</text>
        <view v-if="currentTab === index" class="tab-underline"></view>
