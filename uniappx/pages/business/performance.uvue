  font-size: 26rpx;
  color: #FFFFFF;
}

/* 排名区域 */
.rank-section {
  padding: 20rpx 24rpx;
}

.rank-header {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.rank-title {
  font-size: 30rpx;
