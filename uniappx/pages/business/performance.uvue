}

/* 排名项 */
.rank-item {
  flex-direction: row;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

/* 排名徽章 */
.rank-badge {
  width: 56rpx;
