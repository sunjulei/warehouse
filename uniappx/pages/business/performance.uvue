  background-color: #409EFF;
}

.period-text {
  font-size: 24rpx;
  color: #606266;
}

.period-text-active {
  color: #FFFFFF;
  font-weight: bold;
}

/* 自定义日期 */
.custom-date-row {
  flex-direction: row;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.date-picker-wrap {
  flex: 1;
  flex-direction: column;
  gap: 4rpx;
}

