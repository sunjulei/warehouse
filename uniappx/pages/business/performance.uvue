  font-size: 22rpx;
  color: #909399;
}

.date-display {
  background-color: #F5F7FA;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  border-width: 1rpx;
  border-style: solid;
  border-color: #DCDFE6;
}

.date-value {
  font-size: 26rpx;
  color: #333333;
}

.date-separator {
  font-size: 26rpx;
