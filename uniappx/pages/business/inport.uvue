  background-color: #F5F7FA;
  color: #303133;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 12rpx;
  justify-content: center;
  align-items: center;
  padding: 0;
  line-height: 72rpx;
}

.qty-value {
