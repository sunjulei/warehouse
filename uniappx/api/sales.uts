import { get, post, postJson } from './request'

export function loadAllSales(params: any) {
  return get('/sales/loadAllSales', params)
}

export function addSales(data: any) {
  return post('/sales/addSales', data)
}

export function batchAddSales(data: any[]) {
  return postJson('/sales/batchAddSales', data)
}
