import { get, post } from './request'

export function getNowUser() {
  return get('/user/getNowUser')
}

export function updateUserInfo(data: any) {
  return post('/user/updateUserInfo', data)
}

export function changePassword(oldPassword: string, newPwdOne: string, newPwdTwo: string) {
  return post('/user/changePassword', { oldPassword, newPwdOne, newPwdTwo })
}
